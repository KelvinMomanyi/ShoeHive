<div id="newsletter-popup" class="newsletter-popup">
    <div class="newsletter-popup-content">
      <button class="close-popup" onclick="closePopup()">
        <ion-icon name="close-outline" aria-hidden="true"></ion-icon>
      </button>
      <div class="newsletter-card">
        <div class="card-image">
          <img src="{{'shoes.jpg' | asset_url}}" alt="Newsletter Image">
        </div>
        <div class="newcard-content">
          <h2>Stay Updated!</h2>
          <p>Subscribe to our newsletter and get the latest updates right in your inbox.</p>
          {% form 'customer' %}
          <form action="{{ shop.url }}/contact#contact_form" method="post" accept-charset="UTF-8" class="subscribe-form">
            <input type="hidden" name="form_type" value="customer">
            <input type="hidden" name="utf8" value="✓">
            <input type="email" name="contact[email]" placeholder="Enter your email" required>
            <button type="submit">Subscribe</button>
          </form>
        {% endform %}
        </div>
      </div>
    </div>
  </div>
  

{% comment %} <div id="myModal" class="modal">
    <div class="modal-content">
        <button class="nav-close-btn" onclick="closeModal()">
            <ion-icon name="close-outline" aria-hidden="true" ></ion-icon>
        </button>
        <div class="newsletter-card">
          <div class="card-image">
            <img src="{{'shoes.jpg' | asset_url}}" alt="Newsletter Image">
          </div>
          <div class="newcard-content">
            <h2>Stay Updated!</h2>
            <p>Subscribe to our newsletter and get the latest updates right in your inbox.</p>
            {% form 'customer' %}
            <form class="subscribe-form">
                <div class="email">
                  <label for="email">Email</label>
                  <input type="email" name="contact[email]" />
                </div>
              
                <div class="submit">
                  <input type="submit" value="Sign up" />
                </div>
             </form> 
              {% endform %}

              {% comment %} <input type="email" placeholder="Enter your email" required>
              <button type="submit">Subscribe</button> {% endcomment %}

          </div>
        </div>
     </div>
</div>  {% endcomment %}

<style>
    .newsletter-popup {
        display: none; /* Hidden by default */
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(0, 0, 0, 0.5);
        justify-content: center;
        align-items: center;
        z-index: 1000;
      }
      
      .newsletter-popup-content {
        background: white;
        border-radius: 10px;
        padding: 20px;
        max-width: 600px;
        width: 90%;
        position: relative;
      }
      
 
    .newsletter-card {
      display: flex;
      width: 100%;
      max-width: 800px;
      margin: 0 auto;
      box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
      border-radius: 10px;
      overflow: hidden;
    }
    
    .card-image {
      flex: 1;
      position: relative;
    }
    
    .card-image img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }
    
    .newcard-content {
      flex: 1;
      background-color: #f8f9fa;
      padding: 40px;
      display: flex;
      flex-direction: column;
      justify-content: center;
    }
    
    .newcard-content h2 {
      margin: 0 0 15px;
      font-size: 24px;
      color: #333;
    }
    
    .newcard-content p {
      margin: 0 0 20px;
      font-size: 16px;
      color: #555;
    }
    
    .subscribe-form {
      display: flex;
    }
    
    .subscribe-form input[type="email"] {
      flex: 1;
      padding: 10px 15px;
      font-size: 16px;
      border: 1px solid #ddd;
      border-radius: 5px 0 0 5px;
      outline: none;
    }
    
    .subscribe-form button {
      padding: 10px 20px;
      font-size: 16px;
      background-color: #007bff;
      color: white;
      border: none;
      border-radius: 0 5px 5px 0;
      cursor: pointer;
      transition: background-color 0.3s;
    }
    
    .subscribe-form button:hover {
      background-color: #0056b3;
    }
    
  </style>

  <script>
    document.addEventListener('DOMContentLoaded', function() {
        const popup = document.getElementById('newsletter-popup');
        const cookieName = 'newsletterPopupSeen';
      
        function showPopup() {
          popup.style.display = 'flex';
        }
      
        function closePopup() {
          popup.style.display = 'none';
          // Set a cookie to remember that the user has seen the popup
          document.cookie = `${cookieName}=true; max-age=86400; path=/`; // Cookie expires in 1 day
        }
      
        // Check if the popup has been shown before
        if (!document.cookie.split('; ').find(row => row.startsWith(cookieName))) {
          // Show the popup after 5 seconds (5000 milliseconds)
          setTimeout(showPopup, 5000);
        }
      
        // Add event listener to close the popup
        document.querySelector('.close-popup').addEventListener('click', closePopup);
      });
      
  </script>
  {% schema %}
{
  "name": "newsletter",
  "settings": [],
  "blocks": [],
  "presets": [
    {
      "name": "newsletter"
    }
  ]
}
{% endschema %}