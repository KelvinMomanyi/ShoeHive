{% if section.settings.enabled %}
 <header>
    <div class="alert">
        <div class="container">

          <div class="slider-wrapper">
            {% comment %} <div class="alert-text" id="text1"><p>Members: Free Shipping!</p></div>
            <div class="alert-text" id="text2"><p>Save Up to 40%</p></div>
            <div class="alert-text" id="text3"><p>Get your Gear Faster</p></div> {% endcomment %}
            {% comment %} <p class="alert-text">Free Shipping On All U.S. Orders $50+</p>  {% endcomment %}
            <p class="alert-text" id="text1">Free Shipping On All U.S. Orders $50+</p>
            <p class="alert-text" id="text2">Save Up to 40%</p>
            <p class="alert-text" id="text3">Get your Gear Faster</p>
          </div>

        </div>
    </div>
 </header>
{% endif %}

<style>
  .alert{
    background-color:{{section.settings.background}};
    color:{{section.settings.text_color}};
  }
  .alert-text.visible {
    left: 40%; /* Move to the visible position */
    opacity: 1; /* Fade in */
  }
   {% comment %} .alert-text{
   width:100%;
   } {% endcomment %}
   .alert-text {
    position: absolute;
    left: 50%; /* Start from the middle of the screen horizontally */
    top: 50%; /* Optionally, center vertically as well */
    transform: translateX(-50%) translateY(-50%); /* Adjust for horizontal and vertical centering */
    opacity: 0; /* Start invisible */
    transition: transform 0.5s ease-in-out, opacity 0.5s ease-in-out;
  }
  
  .alert-text.visible {
    opacity: 1; /* Fade in when visible */
  }
  
  .alert-text.exit {
    transform: translateX(150%) translateY(-50%); /* Slide out to the right */
    opacity: 0;
  }

  .slider-wrapper{
   position:relative;
   height:18px;
   width:auto;
   
  }
  #text1, #text2, #text3 {
    width: auto; /* Adjust the width according to your needs */
    height: auto; /* Adjust the height according to your needs */
    position: absolute;
    top: 50%; /* Center vertically */
    transform: translateY(-50%); /* Adjust for vertical centering */
    transition: left 0.5s ease-in-out;
  }

  @media screen and (max-width: 575px){
    .alert-text{
      font-size:12px
    }
    .slider-wrapper{
      height:10px;
     }
    .alert-text.visible {
      left: 20%; /* Move to the visible position */
    }
  }

</style>
<script>
  {% comment %} document.addEventListener('DOMContentLoaded', function(){
    const text1 = document.getElementById('text1');
    const text2 = document.getElementById('text2');
    const text3 = document.getElementById('text3')

    const texts = [text1, text2, text3]
    let currentIndex = 0;
 
   function slideToMiddle(element){
     element.style.left = '50%'
   }
   
   function resetPosition(element){
     element.style.left = '-100%'
   }

   function slideText(){
     resetPosition(texts[currentIndex])
     currentIndex = (currentIndex + 1) % texts.length
     slideToMiddle(texts[currentIndex])
   }

   slideToMiddle(texts[currentIndex])
   
   setInterval(slideText, 3000)

 }) {% endcomment %}
 document.addEventListener('DOMContentLoaded', function() {
  const text1 = document.getElementById('text1');
  const text2 = document.getElementById('text2');
  const text3 = document.getElementById('text3');

  const texts = [text1, text2, text3];
  let currentIndex = 0;

  function slideToMiddle(element) {
    element.classList.add('visible');
  }

  function resetPosition(element) {
    element.classList.remove('visible');
    element.classList.add('exit');
  }

  function slideText() {
    resetPosition(texts[currentIndex]); // Hide the current text
    currentIndex = (currentIndex + 1) % texts.length;
    texts[currentIndex].classList.remove('exit'); // Reset exit state
    slideToMiddle(texts[currentIndex]); // Show the next text
  }

  // Initially, display the first element in the middle
  slideToMiddle(texts[currentIndex]);

  // Change text every 3 seconds
  setInterval(slideText, 3000);
});


</script>
{% schema %}
{
  "name": "announcement-bar",
  "settings": [
    {
     "type": "checkbox",
     "id": "enabled",
     "label": "Enable Announcement Bar",
     "default": true
    },
    {
      "type": "color",
      "id": "background",
      "label": "Background",
      "default": "#000000"
     },
     {
      "type": "color",
      "id": "text_color",
      "label": "Text",
      "default": "#F4F4F4"
     }
  ],
  "blocks": [],
  "presets": [
    {
      "name": "announcement-bar"
    }
  ]
}
{% endschema %}