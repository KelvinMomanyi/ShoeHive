{% if section.settings.enabled %}
 <header>
    <div class="alert">
        <div class="container">
            <p class="alert-text">Free Shipping On All U.S. Orders $50+</p>
        </div>
    </div>
 </header>
{% endif %}

<style>
  .alert{
    background-color:{{section.settings.background}};
    color:{{section.settings.text_color}};
  }
</style>
{% schema %}
{
  "name": "announcement-bar",
  "settings": [
    {
     "type": "checkbox",
     "id": "enabled",
     "label": "Enable Announcement Bar",
     "default": true
    },
    {
      "type": "color",
      "id": " background",
      "label": "Background",
      "default": "#000000"
     },
     {
      "type": "color",
      "id": "text_color",
      "label": "Text",
      "default": "#F4F4F4"
     },
  ],
  "blocks": [],
  "presets": [
    {
      "name": "announcement-bar"
    }
  ]
}
{% endschema %}