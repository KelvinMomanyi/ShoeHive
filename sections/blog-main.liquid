<section class="section hero1" aria-label="home">
    <div class="container">
      <h1 class="h2 hero-title">
        <strong class="strong">See our thoughts, stories and ideas.
      </h1>

      <div class="wrapper1">

        <form action="" class="newsletter-form">
          <input type="email" name="email_address" placeholder="Your email address" class="email-field">

          <button type="submit" class="btn btn-primary">Subscribe</button>
        </form>

        <p class="newsletter-text">
          Get the email newsletter and unlock access to members-only content and updates
        </p>

      </div>

    </div>
  </section>





  <!-- 
    - #FEATURED POST
  -->

  <section class="section featured" aria-label="featured post">
    <div class="container">

      <p class="section-subtitle">
        Get started with our <strong class="strong">best story</strong>
      </p>

      <ul class="has-scrollbar">
        {% for article in blogs['news'].articles %}
         <li class="scrollbar-item">
           <div class="blog-card">

              <figure class="card-banner img-holder" style="--width: 500; --height: 600;">
                 <img src="{{ article.image | img_url: 'medium' }}" width="500" height="600" loading="lazy"
                alt="New technology is not good or evil in and of itself" class="img-cover"/>
              </figure>

              <div class="card-content">

              <ul class="card-meta-list">
                {% for article in article.tags %}
                <li>
                  <a href="#" class="card-tag"> {{ article}}</a>
                </li>
                 {% endfor %}
              </ul>

              <h3 class="h4">
                <a href="#" class="card-title hover:underline">
                  {{ article.title }}
                </a>
              </h3>

              <p class="card-text">
                Vestibulum vehicula dui venenatis neque tempor, accumsan iaculis sapien ornare. Sed at ante porta,
                ullamcorper massa eu,
                ullamcorper sapien. Donec pretium tortor augue. Integer egestas ut tellus sed pretium. Nullam
                tristique augue ut mattis
                vulputate. Duis et lorem in odio ultricies porttitor.
              </p>

              </div>

           </div>
         </li>
         {% endfor %}
      </ul>

    </div>
  </section>
  <!-- 
    - #RECOMMENDED POST
  -->

  <section class="section recommended" aria-label="recommended post">
    <div class="container">

      <p class="section-subtitle">
        <strong class="strong">Recommended</strong>
      </p>

      <ul class="grid-list">
        {% for article in blogs['recommended'].articles %}
        <li>
          <div class="blog-card">

            <figure class="card-banner img-holder" style="--width: 300; --height: 360;">
              <img src="{{ article.image | img_url: 'medium' }}" width="300" height="360" loading="lazy"
                alt="The trick to getting more done is to have the freedom to roam around " class="img-cover">

              {% comment %} <ul class="avatar-list absolute">

                <li class="avatar-item">
                  <a href="#" class="avatar img-holder" style="--width: 100; --height: 100;">
                    <img src="./assets/images/author-5.jpg" width="100" height="100" loading="lazy" alt="Author"
                      class="img-cover">
                  </a>
                </li>

                <li class="avatar-item">
                  <a href="#" class="avatar img-holder" style="--width: 100; --height: 100;">
                    <img src="./assets/images/author-2.jpg" width="100" height="100" loading="lazy" alt="Author"
                      class="img-cover">
                  </a>
                </li>

              </ul> {% endcomment %}
            </figure>

            <div class="card-content">

              <h3 class="h5">
                <a href="#" class="card-title hover:underline">
                  {{ article.title }}
                </a>
              </h3>

            </div>

          </div>
        </li>
      {% endfor  %} 
      </ul>

    </div>
  </section>


 <style>
  .hero1 { padding-block-start: 10px; }

  .blog-card .card-banner {
    position: relative;
    border-radius: var(--radius-16);
    margin-block-end: 15px;
  }
  
  .blog-card .card-title {
    margin-block: 8px 12px;
    /*text-decoration-thickness: 2px;*/
  }
  
