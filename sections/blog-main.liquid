      border-radius: var(--radius-16);
      margin-block-end: 15px;
    }

    .blog-card .card-title {
      margin-block: 8px 12px;
      text-decoration-thickness: 2px;
    }
    
    .blog-card .card-text {
      font-size: var(--fs-9);
      display: -webkit-box;
      -webkit-box-orient: vertical;
      -webkit-line-clamp: 3;
      overflow: hidden;
      padding-inline-end: 20px;
    }
 
    .card-meta-list {
      display: flex;
      gap: 5px;
    }
    @media (min-width: 992px) {
      
        .hero1 .wrapper1 {
            display: flex;
            align-items: center;
            gap: 15px;
          }
      
          .hero1 .newsletter-text {
            display: block;
            max-width: 400px;
            color: var(--eerie-black_80);
            line-height: 1.3;
          }
          .blog-card .card-title { padding-inline-end: 15px; }

           .blog-card .card-text { font-size: unset; }
      
      }

      
      
      
      
      
      /*-----------------------------------*\
        #RESET
      \*-----------------------------------*/
      
      {% comment %} *,
      *::before,
      *::after {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      } {% endcomment %}
      
      li { list-style: none; }
      
      {% comment %} a,
      img,
      span,
      input,
      button,
      ion-icon { display: block; }
      
      a {
        color: inherit;
        text-decoration: none;
      }
      
      img { height: auto; }
      
      input,
      button {
        background: none;
        border: none;
        font: inherit;
      }
      
      input {
        width: 100%;
        outline: none;
      }
      
      button { cursor: pointer; }
      
      ion-icon { pointer-events: none; }
      
      html {
        font-family: var(--ff-inter);
        font-size: 10px;
        scroll-behavior: smooth;
      }
      
      body {
        background-color: var(--white);
        color: var(--eerie-black);
        font-size: 1.6rem;
        line-height: 1.5;
      }
      
      body.active { overflow: hidden; } {% endcomment %}
      
      :focus-visible { outline-offset: 4px; }
      
      ::-webkit-scrollbar { width: 10px; }
      
      ::-webkit-scrollbar-track { background-color: hsl(0, 0%, 98%); }
      
      ::-webkit-scrollbar-thumb { background-color: hsl(0, 0%, 80%); }
      
      ::-webkit-scrollbar-thumb:hover { background-color: hsl(0, 0%, 70%); }
      
      
      
      
      
      /*-----------------------------------*\
        #REUSED STYLE
      \*-----------------------------------*/
      
      .section { margin-inline: 15px; }
      
      .hover\:underline { text-underline-offset: 3px; }
      
      .hover\:underline:is(:hover, :focus) { text-decoration: underline; }
      
      .section:not(.header, .footer-bottom) {
        padding-block-end: var(--section-padding);
        border-block-end: 1px solid var(--light-gray-2);
      }
      
      {% comment %} .h1,
      .h2,
      .h3,
      .h4,
      .h5 { line-height: 1.2; }
      
      .h1,
      .h2 { font-weight: var(--fw-300); }
      
      .h1 { font-size: var(--fs-1); }
      
      .h2 { font-size: var(--fs-2); }
      
      .h3 { font-size: var(--fs-3); }
      
      .h4 { font-size: var(--fs-4); }
      
      .h5 { font-size: var(--fs-6); } {% endcomment %}
      
      {% comment %} .newsletter-form {
        position: relative;
        max-width: 400px;
      }
      
      .newsletter-form .email-field {
        background-color: var(--cultured);
        color: inherit;
        padding: 6px 14px;
        padding-inline-end: 140px;
        border-radius: var(--radius-pill);
      } {% endcomment %}
      
      {% comment %} .newsletter-form .email-field:focus { background-color: var(--gainsboro); }
      
      .newsletter-form .email-field::placeholder { color: var(--eerie-black_60); }
      
      .newsletter-form .btn {
        position: absolute;
        top: 0;
        right: 0;
        bottom: 0;
      }
      
      .btn {
        background-color: var(--eerie-black);
        color: var(--white);
